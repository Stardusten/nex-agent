{
  "id": "builtin:tool.web",
  "title": "Web Tools",
  "version": "0.1.0",
  "enabled": true,
  "source": "builtin",
  "description": "Built-in web search and fetch tools.",
  "contributes": {
    "tools": [
      {
        "name": "web_search",
        "module": "Nex.Agent.Tool.WebSearch",
        "surfaces": ["all", "base", "follow_up", "subagent", "cron"]
      },
      {
        "name": "web_fetch",
        "module": "Nex.Agent.Tool.WebFetch",
        "surfaces": ["all", "base", "follow_up", "subagent", "cron"]
      }
    ]
  }
}
